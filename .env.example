# Database (Neon PostgreSQL via Vercel Marketplace)
DATABASE_URL=postgresql://USER:PASSWORD@your-neon-host.neon.tech/herald?sslmode=require

# Auth.js
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3100

# JIRA
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_USER_EMAIL=your-email@company.com

# Anthropic (AI/LLM)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Slack (메시지에서 요청자 이름 추출)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Vercel Blob (스크린샷 업로드 — Vercel Marketplace에서 자동 주입)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Google OAuth (SSO 로그인 + Gmail API 메일 발송)
# Google Cloud Console 설정 방법:
#   1. https://console.cloud.google.com 에서 새 프로젝트 생성
#   2. API 및 서비스 → Gmail API 활성화
#   3. OAuth 동의 화면 → External 선택 → 테스트 사용자 추가
#   4. 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 생성 (웹 애플리케이션)
#   5. 승인된 리디렉션 URI 추가:
#      - 로컬: http://localhost:3100/api/auth/callback/google
#      - 운영: https://herald.fassto.ai/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
